# .gitignore untuk projek portfolio

# Node
node_modules/

# Build / output
dist/
build/
out/
.next/
.next/cache/
public/build/
.cache/
.cache-loader/
.parcel-cache/
coverage/

# Environment / secrets
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets.json

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.code-workspace

# Deployment / platform artifacts
.vercel/
.netlify/
firebase-debug.log
.wrangler/
.now/

# Misc / temporary
*.log
*.tmp
*.temp
.vscode-test/
*.cache

# Ignore generated lockfiles only if you don't commit them (usually you DO commit lockfiles)
# Uncomment to ignore:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml